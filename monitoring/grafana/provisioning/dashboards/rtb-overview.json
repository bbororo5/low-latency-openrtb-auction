{
  "uid": "rtb-overview",
  "title": "RTB Overview",
  "tags": ["rtb", "openrtb", "baseline"],
  "timezone": "browser",
  "schemaVersion": 40,
  "version": 1,
  "refresh": "5s",
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "SSP Auction Latency p95 / p99",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "fillOpacity": 8,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "legendFormat": "p95 {{result}}",
          "expr": "histogram_quantile(0.95, sum by (le, result) (rate(rtb_ssp_auction_duration_seconds_bucket[$__rate_interval])))"
        },
        {
          "refId": "B",
          "legendFormat": "p99 {{result}}",
          "expr": "histogram_quantile(0.99, sum by (le, result) (rate(rtb_ssp_auction_duration_seconds_bucket[$__rate_interval])))"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Auction Result Rate",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "fillOpacity": 8,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "legendFormat": "{{result}}",
          "expr": "sum by (result) (rate(rtb_ssp_auction_result_total[$__rate_interval]))"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "SSP -> DSP Call Latency p95",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "fillOpacity": 8,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "legendFormat": "{{dsp_id}} {{result}}",
          "expr": "histogram_quantile(0.95, sum by (le, dsp_id, result) (rate(rtb_ssp_dsp_call_duration_seconds_bucket[$__rate_interval])))"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "DSP Terminal Result Rate",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "fillOpacity": 8,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "legendFormat": "{{dsp_id}} {{result}}",
          "expr": "sum by (dsp_id, result) (rate(rtb_ssp_dsp_terminal_result_total[$__rate_interval]))"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "DSP Bid Handling Latency p95",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 16
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "fillOpacity": 8,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "legendFormat": "{{job}} {{result}}",
          "expr": "histogram_quantile(0.95, sum by (le, job, result) (rate(rtb_dsp_bid_handle_duration_seconds_bucket[$__rate_interval])))"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "DSP Bid Result Rate",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 16
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "fillOpacity": 8,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "legendFormat": "{{job}} {{result}}",
          "expr": "sum by (job, result) (rate(rtb_dsp_bid_result_total[$__rate_interval]))"
        }
      ]
    }
  ]
}
