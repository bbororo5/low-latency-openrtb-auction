{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Grafana Cloud Prometheus datasource",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "uid": "rtb-auction-overview",
  "title": "RTB Auction Overview",
  "tags": [
    "rtb",
    "openrtb",
    "auction",
    "aws-perf"
  ],
  "timezone": "browser",
  "schemaVersion": 40,
  "version": 1,
  "refresh": "5s",
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "environment",
        "type": "constant",
        "query": "aws-perf",
        "current": {
          "selected": true,
          "text": "aws-perf",
          "value": "aws-perf"
        },
        "hide": 2
      },
      {
        "name": "project",
        "type": "constant",
        "query": "low-latency-openrtb-auction",
        "current": {
          "selected": true,
          "text": "low-latency-openrtb-auction",
          "value": "low-latency-openrtb-auction"
        },
        "hide": 2
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Winner RPS",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(rtb_ssp_auction_result_total{scrape_job=\"rtb-ssp\", result=\"winner\"}[$__rate_interval]))",
          "legendFormat": "winner"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "No Winner RPS",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 1
              },
              {
                "color": "red",
                "value": 10
              }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(rtb_ssp_auction_result_total{scrape_job=\"rtb-ssp\", result=\"no_winner\"}[$__rate_interval]))",
          "legendFormat": "no_winner"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "DSP Error RPS",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 12,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(rtb_ssp_dsp_call_result_total{scrape_job=\"rtb-ssp\", result=\"error\"}[$__rate_interval]))",
          "legendFormat": "dsp_error"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "SSP Auction p99",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 18,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 3,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 0.05
              },
              {
                "color": "red",
                "value": 0.12
              }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.99, sum by (le) (rate(rtb_ssp_auction_duration_seconds_bucket{scrape_job=\"rtb-ssp\"}[$__rate_interval])))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Auction Result Rate",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 5
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "fillOpacity": 8,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (result) (rate(rtb_ssp_auction_result_total{scrape_job=\"rtb-ssp\"}[$__rate_interval]))",
          "legendFormat": "{{result}}"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "SSP Auction Latency p95 / p99",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 5
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "fillOpacity": 8,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le, result) (rate(rtb_ssp_auction_duration_seconds_bucket{scrape_job=\"rtb-ssp\"}[$__rate_interval])))",
          "legendFormat": "p95 {{result}}"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.99, sum by (le, result) (rate(rtb_ssp_auction_duration_seconds_bucket{scrape_job=\"rtb-ssp\"}[$__rate_interval])))",
          "legendFormat": "p99 {{result}}"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "SSP -> DSP Call Rate",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 13
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "fillOpacity": 8,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (dsp_id, result) (rate(rtb_ssp_dsp_call_result_total{scrape_job=\"rtb-ssp\"}[$__rate_interval]))",
          "legendFormat": "{{dsp_id}} {{result}}"
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "SSP -> DSP Call Latency p95 / p99",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 13
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "fillOpacity": 8,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le, dsp_id, result) (rate(rtb_ssp_dsp_call_duration_seconds_bucket{scrape_job=\"rtb-ssp\"}[$__rate_interval])))",
          "legendFormat": "p95 {{dsp_id}} {{result}}"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.99, sum by (le, dsp_id, result) (rate(rtb_ssp_dsp_call_duration_seconds_bucket{scrape_job=\"rtb-ssp\"}[$__rate_interval])))",
          "legendFormat": "p99 {{dsp_id}} {{result}}"
        }
      ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "DSP Bid Result Rate",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 21
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "fillOpacity": 8,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (scrape_job, result) (rate(rtb_dsp_bid_result_total{scrape_job=~\"rtb-dsp-.*\"}[$__rate_interval]))",
          "legendFormat": "{{scrape_job}} {{result}}"
        }
      ]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "DSP Bid Handling Latency p95 / p99",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 21
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "fillOpacity": 8,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le, scrape_job, result) (rate(rtb_dsp_bid_handle_duration_seconds_bucket{scrape_job=~\"rtb-dsp-.*\"}[$__rate_interval])))",
          "legendFormat": "p95 {{scrape_job}} {{result}}"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.99, sum by (le, scrape_job, result) (rate(rtb_dsp_bid_handle_duration_seconds_bucket{scrape_job=~\"rtb-dsp-.*\"}[$__rate_interval])))",
          "legendFormat": "p99 {{scrape_job}} {{result}}"
        }
      ]
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "DSP No-Bid Reason Rate",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 29
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "fillOpacity": 8,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (scrape_job, reason) (rate(rtb_dsp_no_bid_reason_total{scrape_job=~\"rtb-dsp-.*\"}[$__rate_interval]))",
          "legendFormat": "{{scrape_job}} {{reason}}"
        }
      ]
    }
  ]
}
