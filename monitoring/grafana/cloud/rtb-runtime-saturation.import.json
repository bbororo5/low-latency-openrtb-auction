{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Grafana Cloud Prometheus datasource",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "uid": "rtb-runtime-saturation",
  "title": "RTB Runtime Saturation",
  "tags": ["rtb", "openrtb", "runtime", "saturation", "aws-perf"],
  "timezone": "browser",
  "schemaVersion": 40,
  "version": 1,
  "refresh": "5s",
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "SSP Live Threads",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 5, "w": 6, "x": 0, "y": 0},
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "orange", "value": 500},
              {"color": "red", "value": 1000}
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "jvm_threads_live_threads{scrape_job=\"rtb-ssp\"}",
          "legendFormat": "ssp"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "SSP Peak Threads",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 5, "w": 6, "x": 6, "y": 0},
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "orange", "value": 1000},
              {"color": "red", "value": 2000}
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "jvm_threads_peak_threads{scrape_job=\"rtb-ssp\"}",
          "legendFormat": "ssp"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "SSP In-Flight DSP Calls",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 5, "w": 6, "x": 12, "y": 0},
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "orange", "value": 300},
              {"color": "red", "value": 1000}
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "rtb_ssp_dsp_inflight_calls{scrape_job=\"rtb-ssp\"}",
          "legendFormat": "in_flight"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "SSP Process CPU",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 5, "w": 6, "x": 18, "y": 0},
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "orange", "value": 0.7},
              {"color": "red", "value": 0.9}
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "process_cpu_usage{scrape_job=\"rtb-ssp\"}",
          "legendFormat": "ssp"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Live Threads by Service",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 5},
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {"drawStyle": "line", "lineInterpolation": "linear", "lineWidth": 2, "fillOpacity": 8, "showPoints": "never"}
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "jvm_threads_live_threads{scrape_job=~\"rtb-.*\"}",
          "legendFormat": "{{scrape_job}} live"
        },
        {
          "refId": "B",
          "expr": "jvm_threads_peak_threads{scrape_job=~\"rtb-.*\"}",
          "legendFormat": "{{scrape_job}} peak"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Thread States by Service",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 5},
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {"drawStyle": "line", "lineInterpolation": "linear", "lineWidth": 2, "fillOpacity": 8, "showPoints": "never"}
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "jvm_threads_states_threads{scrape_job=~\"rtb-.*\"}",
          "legendFormat": "{{scrape_job}} {{state}}"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "SSP In-Flight DSP Calls",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 13},
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {"drawStyle": "line", "lineInterpolation": "linear", "lineWidth": 2, "fillOpacity": 12, "showPoints": "never"}
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "rtb_ssp_dsp_inflight_calls{scrape_job=\"rtb-ssp\"}",
          "legendFormat": "in_flight"
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Process CPU Usage",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 13},
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "custom": {"drawStyle": "line", "lineInterpolation": "linear", "lineWidth": 2, "fillOpacity": 8, "showPoints": "never"}
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "process_cpu_usage{scrape_job=~\"rtb-.*\"}",
          "legendFormat": "{{scrape_job}}"
        }
      ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Heap Used",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 21},
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {"drawStyle": "line", "lineInterpolation": "linear", "lineWidth": 2, "fillOpacity": 8, "showPoints": "never"}
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (scrape_job) (jvm_memory_used_bytes{scrape_job=~\"rtb-.*\", area=\"heap\"})",
          "legendFormat": "{{scrape_job}}"
        }
      ]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "GC Pause p95",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 21},
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {"drawStyle": "line", "lineInterpolation": "linear", "lineWidth": 2, "fillOpacity": 8, "showPoints": "never"}
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le, scrape_job) (rate(jvm_gc_pause_seconds_bucket{scrape_job=~\"rtb-.*\"}[$__rate_interval])))",
          "legendFormat": "{{scrape_job}} p95"
        }
      ]
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Metric Scrape Health",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 6, "w": 24, "x": 0, "y": 29},
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {"drawStyle": "line", "lineInterpolation": "linear", "lineWidth": 2, "fillOpacity": 8, "showPoints": "never"}
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "up{scrape_job=~\"rtb-.*\"}",
          "legendFormat": "{{scrape_job}}"
        }
      ]
    }
  ]
}
