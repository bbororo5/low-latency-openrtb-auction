# Copy this file to .env.grafana-cloud and fill in values from the Grafana Cloud OpenTelemetry connection tile.
GRAFANA_CLOUD_OTLP_ENDPOINT=https://<grafana-cloud-otlp-endpoint>/otlp
GRAFANA_CLOUD_OTLP_USERNAME=<instance-id>
GRAFANA_CLOUD_OTLP_API_KEY=<token>

# Raise to 1.0 temporarily when verifying smoke traces, then restore 0.10 for load tests.
OTEL_TRACES_SAMPLER_ARG=0.10
